rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: registrations
    // Fields:
    //   - parentName: string (required)
    //   - phone: string (required)
    //   - studentName: string (required)
    //   - studentClass: string (required)
    //   - subjects: list (optional)
    //   - note: string (optional)
    //   - createdAt: timestamp (required)
    //   - status: string (required, enum: ['new', 'contacted', 'enrolled'])
    //
    // Collection: testimonials
    // Fields:
    //   - name: string (required)
    //   - role: string (required)
    //   - content: string (required)
    //   - rating: number (required, 1-5)
    //   - approved: bool (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Fields:
    //   - name: string
    //   - email: string
    //   - role: string (admin/user)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "appbanhangai@gmail.com"
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if timestamp is recent (within 1 minute)
    function isRecent(time) {
      return time > request.time - duration.value(1, 'm') &&
             time <= request.time;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validation Functions
    function isValidRegistration(data) {
      return (data.phone is string && data.phone.size() >= 3) &&
             (data.studentName is string && data.studentName.size() > 0) &&
             (data.status in ['new', 'contacted', 'enrolled', 'paid']) &&
             (data.createdAt is timestamp) &&
             (!('parentName' in data) || data.parentName is string) &&
             (!('studentClass' in data) || data.studentClass is string) &&
             (!('subjects' in data) || data.subjects is list) &&
             (!('courseTitle' in data) || data.courseTitle is string) &&
             (!('paymentAmount' in data) || data.paymentAmount is string) &&
             (!('note' in data) || data.note is string);
    }

    function isValidTestimonial(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.approved is bool;
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 9 && data.phone.size() <= 15 &&
             data.school is string && data.school.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.class is string && data.class.size() > 0 &&
             (!('subjects' in data) || data.subjects is list) &&
             (!('photoUrl' in data) || data.photoUrl is string);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                    hasOnlyAllowedFields(['name', 'email', 'role', 'createdAt']) &&
                    request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /registrations/{regId} {
      allow read, update, delete: if isAdmin();
      allow create: if isValidRegistration(request.resource.data);
    }

    match /testimonials/{testId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read, write: if isAdmin();
    }
  }
}
