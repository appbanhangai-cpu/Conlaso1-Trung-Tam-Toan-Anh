rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "appbanhangai@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Assumed Data Model: Registration
    // ===============================================================
    // Collection: registrations
    // Fields:
    //   - parentName: string (required)
    //   - phone: string (required, length 10-15)
    //   - studentName: string (required)
    //   - studentClass: string (required)
    //   - subjects: list (optional)
    //   - note: string (optional)
    //   - createdAt: timestamp (required)
    //   - status: string (required, enum: ['new', 'contacted', 'enrolled'])
    // ===============================================================

    function isValidRegistration(data) {
      return data.keys().hasAll(['parentName', 'phone', 'studentName', 'studentClass', 'createdAt', 'status']) &&
             data.parentName is string && data.parentName.size() > 0 && data.parentName.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 100 &&
             data.studentClass is string &&
             data.createdAt is timestamp &&
             data.status in ['new', 'contacted', 'enrolled'];
    }

    match /registrations/{registrationId} {
      // Anyone can create a registration
      allow create: if isValidRegistration(request.resource.data);
      
      // Only admin can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    // ===============================================================
    // Assumed Data Model: Testimonial
    // ===============================================================
    // Collection: testimonials
    // Fields:
    //   - name: string (required)
    //   - role: string (required)
    //   - content: string (required)
    //   - rating: number (required, 1-5)
    //   - approved: boolean (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'role', 'content', 'rating', 'approved', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 50 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.approved is bool &&
             data.createdAt is timestamp;
    }

    match /testimonials/{testimonialId} {
      // Anyone can read approved testimonials
      allow read: if resource.data.approved == true || isAdmin();
      
      // Anyone can create a testimonial (default unapproved)
      allow create: if isValidTestimonial(request.resource.data) && request.resource.data.approved == false;
      
      // Only admin can update or delete
      allow update, delete: if isAdmin();
    }
  }
}
